{
  "info": {
    "name": "MonLivres API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection Postman pour l’API MonLivres"
  },
  "item": [
    {
      "name": "Register utilisateur",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nom\": \"Client Test\",\n  \"email\": \"client@test.com\",\n  \"password\": \"Passw0rd123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "register"]
        }
      }
    },
    {
      "name": "Login utilisateur",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"client@test.com\",\n  \"password\": \"Passw0rd123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "Liste catégories",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/categories",
          "host": ["{{baseUrl}}"],
          "path": ["api", "categories"]
        }
      }
    },
    {
      "name": "Liste ouvrages",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/ouvrages",
          "host": ["{{baseUrl}}"],
          "path": ["api", "ouvrages"]
        }
      }
    },
    {
      "name": "Ajouter au panier",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "{{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"ouvrage_id\": 1,\n  \"quantite\": 2\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/panier/items",
          "host": ["{{baseUrl}}"],
          "path": ["api", "panier", "items"]
        }
      }
    },
    {
      "name": "Créer commande",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "{{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"adresse_livraison\": \"123 rue de Test\",\n  \"mode_livraison\": \"Standard\",\n  \"mode_paiement\": \"Carte\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/commandes",
          "host": ["{{baseUrl}}"],
          "path": ["api", "commandes"]
        }
      }
    },
    {
      "name": "Soumettre avis",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "{{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"note\": 5,\n  \"commentaire\": \"Très bon livre\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/ouvrages/1/avis",
          "host": ["{{baseUrl}}"],
          "path": ["api", "ouvrages", "1", "avis"]
        }
      }
    },
    {
      "name": "Soumettre commentaire",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "{{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"contenu\": \"J’aimerais voir plus de détails sur ce livre\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/ouvrages/1/commentaires",
          "host": ["{{baseUrl}}"],
          "path": ["api", "ouvrages", "1", "commentaires"]
        }
      }
    }
  ]
}
